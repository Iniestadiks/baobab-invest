generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  INVESTOR
  ENTREPRENEUR
  ADMIN
  MENTOR
}

enum KycStatus {
  NOT_SUBMITTED
  PENDING
  VERIFIED
  REJECTED
}

enum SupplierStatus {
  PENDING
  VERIFIED
  SUSPENDED
}

enum ProjectStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  FUNDED
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  INVESTMENT
  RETURN
  COMMISSION
  GUARANTEE_FUND
  REFUND
  SUPPLIER_PAYMENT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum MilestoneStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
  PAID
}

enum ReactionType {
  TRUST
  WORRY
  BRAVO
}

enum ProjectSector {
  AGRICULTURE
  COMMERCE
  TECH
  ARTISANAT
  EDUCATION
  SANTE
  SERVICES
  ENERGIE
  TRANSPORT
  AUTRE
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

model User {
  id                String     @id @default(uuid())
  email             String     @unique
  phone             String     @unique
  password          String
  firstName         String
  lastName          String
  role              UserRole   @default(INVESTOR)
  isEmailVerified   Boolean    @default(false)
  isPhoneVerified   Boolean    @default(false)
  isActive          Boolean    @default(true)
  isBanned          Boolean    @default(false)
  banReason         String?
  bannedAt          DateTime?
  rehabilitationAt  DateTime?
  kycStatus         KycStatus  @default(NOT_SUBMITTED)
  kycDocumentUrl    String?
  kycSelfieUrl      String?
  kycRccmUrl        String?
  kycVerifiedAt     DateTime?
  kycSubmittedAt    DateTime?
  kycRejectedReason String?
  kycDocumentExpiry DateTime?
  kycDocumentType   String?
  kycVerifiedBy     String?
  kycAttempts       Int       @default(0)
  kycNotes          String?
  profileImageUrl   String?
  bio               String?
  city              String?
  country           String     @default("SN")
  level             Int        @default(1)
  reputationScore      Int      @default(100)
  savingsPlans        SavingsPlan[]
  sentMessages        Message[] @relation("SentMessages")
  walletTransactions  WalletTransaction[]
  receivedMessages    Message[] @relation("ReceivedMessages")
  totalInvested     Float      @default(0)
  totalEarned       Float      @default(0)
  monthlyInvestmentLimit Float @default(500000)
  referralCode      String?   @unique
  referralCount     Int       @default(0)
  referralEarned    Float     @default(0)
  referredBy        String?
  refreshToken      String?
  otpCode           String?
  otpExpiresAt      DateTime?
  fcmToken          String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  wallet              Wallet?
  projectsOwned       Project[]      @relation("EntrepreneurProjects")
  investments         Investment[]
  mentoredProjects    Project[]      @relation("MentorProjects")
  posts         Post[]
  postReactions       PostReaction[]
  notifications       Notification[]
  transactions        Transaction[]
  guaranteeFundContributions GuaranteeFund[]

  @@map("users")
}

model Supplier {
  id              String         @id @default(uuid())
  companyName     String
  contactName     String
  email           String         @unique
  phone           String         @unique
  sector          String
  city            String
  country         String         @default("SN")
  rccmNumber      String?
  nineaNumber     String?
  mobileMoneyNumber String
  mobileMoneyProvider String
  description     String?
  logoUrl         String?
  status          SupplierStatus @default(PENDING)
  isVerified      Boolean        @default(false)
  verifiedAt      DateTime?
  isPremium       Boolean        @default(false)
  rating          Float          @default(0)
  totalPayments   Float          @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  milestonePayments MilestonePayment[]
  milestones        Milestone[]

  @@map("suppliers")
}

model Wallet {
  id              String   @id @default(uuid())
  userId          String   @unique
  balance         Float    @default(0)
  escrowBalance   Float    @default(0)
  totalDeposited  Float    @default(0)
  totalWithdrawn  Float    @default(0)
  commissionBalance  Float    @default(0)
  guaranteeBalance   Float    @default(0)
  escrowInvestors    Float    @default(0)
  totalEarned     Float    @default(0)
  totalInvested   Float    @default(0)
  guaranteeFund   Float    @default(0)
  currency        String   @default("XOF")
  scheduledAmount Float    @default(0)
  scheduledDay    Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("wallets")
}

model Project {
  id                  String        @id @default(uuid())
  entrepreneurId      String
  mentorId            String?
  title               String
  description         String
  sector              ProjectSector @default(AUTRE)
  city                String
  country             String        @default("SN")
  goalAmount          Float
  raisedAmount        Float         @default(0)
  minimumInvestment   Float         @default(500)
  expectedReturn      Float
  durationMonths      Int
  status              ProjectStatus @default(DRAFT)
  riskLevel           RiskLevel     @default(MEDIUM)
  pitchVideoUrl       String?
  coverImageUrl       String?
  businessPlanUrl     String?
  investorCount       Int           @default(0)
  campaignEndsAt      DateTime?
  bankabilityScore    Int           @default(0)
  reputationScore      Int      @default(100)
  commissionRate      Float         @default(4)
  commissionPaid      Float         @default(0)
  guaranteeFundAmount Float         @default(0)
  contractSignedAt    DateTime?
  contractUrl         String?
  adminNote           String?
  viewCount           Int           @default(0)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  entrepreneur  User         @relation("EntrepreneurProjects", fields: [entrepreneurId], references: [id])
  mentor        User?        @relation("MentorProjects", fields: [mentorId], references: [id])
  investments   Investment[]
  milestones    Milestone[]
  posts         Post[]
  messages      Message[]
  savingsPlans  SavingsPlan[]
  guaranteeFund       GuaranteeFund[]
  repaymentSchedules  RepaymentSchedule[]
  repaymentPayments   RepaymentPayment[]

  @@map("projects")
}

model Investment {
  id             String            @id @default(uuid())
  userId         String
  projectId      String
  amount         Float
  guaranteeContribution Float      @default(0)
  expectedReturn Float
  status         TransactionStatus @default(PENDING)
  returnedAmount Float             @default(0)
  returnRate     Float             @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  project Project @relation(fields: [projectId], references: [id])

  @@map("investments")
}

model Milestone {
  id            String          @id @default(uuid())
  projectId     String
  title         String
  description   String
  amount        Float
  status        MilestoneStatus @default(PENDING)
  proofUrl      String?
  invoiceUrl    String?
  supplierId    String?
  adminNote     String?
  dueDate       DateTime?
  paidAt        DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  project  Project            @relation(fields: [projectId], references: [id])
  payments   MilestonePayment[]
  supplier      Supplier?          @relation(fields: [supplierId], references: [id])

  @@map("milestones")
}

model MilestonePayment {
  id           String            @id @default(uuid())
  milestoneId  String
  supplierId   String
  amount       Float
  status       TransactionStatus @default(PENDING)
  reference    String            @unique @default(uuid())
  paidAt       DateTime?
  proofUrl     String?
  createdAt    DateTime          @default(now())

  milestone Milestone @relation(fields: [milestoneId], references: [id])
  supplier  Supplier  @relation(fields: [supplierId], references: [id])

  @@map("milestone_payments")
}

model GuaranteeFund {
  id        String   @id @default(uuid())
  userId    String
  projectId String
  amount    Float
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  project Project @relation(fields: [projectId], references: [id])

  @@map("guarantee_fund")
}

model Transaction {
  id          String            @id @default(uuid())
  userId      String
  type        TransactionType
  amount      Float
  currency    String            @default("XOF")
  status      TransactionStatus @default(PENDING)
  reference   String            @unique @default(uuid())
  description String?
  metadata    Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("transactions")
}

model Post {
  id          String   @id @default(uuid())
  authorId    String
  projectId   String
  content     String
  mediaUrls   String[]
  likesCount  Int      @default(0)
  trustCount  Int      @default(0)
  worryCount  Int      @default(0)
  bravoCount  Int      @default(0)
  isRequired  Boolean  @default(false)
  dueDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author    User           @relation(fields: [authorId], references: [id])
  project   Project        @relation(fields: [projectId], references: [id])
  reactions PostReaction[]

  @@map("posts")
}

model PostReaction {
  id        String       @id @default(uuid())
  postId    String
  userId    String
  type      ReactionType
  createdAt DateTime     @default(now())

  post Post @relation(fields: [postId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
  @@map("post_reactions")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  type      String
  isRead    Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model Message {
  id          String   @id @default(cuid())
  fromUserId  String
  toUserId    String
  content     String
  projectId   String?
  isRead      Boolean  @default(false)
  attachmentUrl String?
  attachmentName String?
  attachmentType String?
  createdAt   DateTime @default(now())

  fromUser    User     @relation("SentMessages", fields: [fromUserId], references: [id])
  toUser      User     @relation("ReceivedMessages", fields: [toUserId], references: [id])
  project     Project? @relation(fields: [projectId], references: [id])

  @@map("messages")
}

model SavingsPlan {
  id              String   @id @default(cuid())
  userId          String
  projectId       String?
  amount          Float
  frequency       String   @default("WEEKLY")
  dayOfWeek       Int      @default(5)
  isActive        Boolean  @default(true)
  nextExecutionAt DateTime
  lastExecutedAt  DateTime?
  totalExecutions Int      @default(0)
  totalInvested   Float    @default(0)
  createdAt       DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])

  @@map("savings_plans")
}

model PlatformRevenue {
  id          String   @id @default(cuid())
  type        String   // COMMISSION_COLLECTION, COMMISSION_RETURN, WITHDRAWAL_FEE, SUCCESS_FEE
  amount      Float
  projectId   String?
  investmentId String?
  description String?
  createdAt   DateTime @default(now())

  @@map("platform_revenues")
}

model WalletTransaction {
  id          String   @id @default(uuid())
  userId      String
  type        String   // DEPOSIT, WITHDRAWAL
  amount      Float
  status      String   @default("PENDING") // PENDING, COMPLETED, REJECTED
  phoneNumber String?
  operator    String?
  description String?
  processedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
  @@map("wallet_transactions")
}

model PlatformConfig {
  id          String   @id @default(uuid())
  key         String   @unique
  value       Float
  label       String
  description String?
  updatedAt   DateTime @updatedAt
  updatedBy   String?
  @@map("platform_config")
}

model RepaymentSchedule {
  id              String   @id @default(uuid())
  projectId       String
  totalAmount     Float
  monthlyAmount   Float
  totalMonths     Int
  paidMonths      Int      @default(0)
  remainingAmount Float
  nextDueDate     DateTime?
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  project         Project  @relation(fields: [projectId], references: [id])
  payments        RepaymentPayment[]
  @@map("repayment_schedules")
}

model RepaymentPayment {
  id           String    @id @default(uuid())
  scheduleId   String
  projectId    String
  amount       Float
  monthNumber  Int
  status       String    @default("PENDING")
  paidAt       DateTime?
  dueDate      DateTime?
  createdAt    DateTime  @default(now())
  schedule     RepaymentSchedule @relation(fields: [scheduleId], references: [id])
  project      Project   @relation(fields: [projectId], references: [id])
  @@map("repayment_payments")
}
